---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const DEFAULT_CATEGORY = '其他';
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Build category → posts mapping; uncategorized goes to "其他"
const categoryMap = new Map<string, typeof posts>();

for (const post of posts) {
  const cats = post.data.categories && post.data.categories.length > 0
    ? post.data.categories
    : [DEFAULT_CATEGORY];
  for (const cat of cats) {
    if (!categoryMap.has(cat)) categoryMap.set(cat, []);
    categoryMap.get(cat)!.push(post);
  }
}

// Sort categories: "其他" always last
const allCategories = Array.from(categoryMap.keys()).sort((a, b) => {
  if (a === DEFAULT_CATEGORY) return 1;
  if (b === DEFAULT_CATEGORY) return -1;
  return a.localeCompare(b);
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Categories" wide={true}>
  <section class="pt-16 sm:pt-24 pb-16">
    <div class="grid grid-cols-12 gap-8 lg:gap-16 items-start">

      <div class="col-span-12 lg:col-span-8">
        <div class="flex items-center gap-3 mb-10">
          <span class="font-mono text-[10.5px] uppercase tracking-[0.24em] text-ink-500">— Categories</span>
          <span class="h-px flex-1 max-w-[60px] bg-ink-200"></span>
          <span class="font-mono text-[10.5px] uppercase tracking-[0.24em] text-ink-300">№ 03</span>
        </div>

        <h1 class="font-display leading-[1] text-[clamp(2.5rem,7vw,6rem)] tracking-[-0.035em] text-ink-900">
          Browse by <span class="display-italic text-accent">category</span>,
          <br/>find your path<span class="text-accent">.</span>
        </h1>

        <p class="mt-10 max-w-[44ch] font-serif text-lg text-ink-500 leading-[1.75]">
          每一篇文章都属于一个分类。没有明确归类的，统一放在「其他」里。
        </p>
      </div>

      <aside class="col-span-12 lg:col-span-4 lg:pt-4 space-y-8">
        <div class="hairline-t pt-4 grid grid-cols-2 gap-2 font-mono text-[10.5px] uppercase tracking-[0.18em]">
          <div>
            <p class="text-ink-300">Categories</p>
            <p class="mt-1 font-display text-2xl tabular-nums text-ink-900 tracking-tight">{String(allCategories.length).padStart(2, '0')}</p>
          </div>
          <div>
            <p class="text-ink-300">Entries</p>
            <p class="mt-1 font-display text-2xl tabular-nums text-ink-900 tracking-tight">{String(posts.length).padStart(2, '0')}</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {/* Category sections */}
  <div class="space-y-20">
    {allCategories.map((cat) => {
      const catPosts = categoryMap.get(cat)!;
      const latestPosts = catPosts.slice(0, 3);
      const hasMore = catPosts.length > 3;
      return (
        <section>
          <div class="flex items-baseline justify-between mb-2 reveal hairline-t pt-6">
            <h2 class="font-display text-4xl sm:text-5xl text-ink-900 leading-none">
              <a href={`${base}/blog?category=${encodeURIComponent(cat)}`} class="group hover:text-accent transition-colors">
                {cat}
                <span class="link-arrow inline-block ml-2 text-2xl text-ink-300 group-hover:text-accent transition-all">→</span>
              </a>
            </h2>
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500">
              {catPosts.length} {catPosts.length > 1 ? 'entries' : 'entry'}
            </span>
          </div>
          <div class="grid grid-cols-12 gap-8 lg:gap-16">
            <div class="col-span-12 lg:col-span-8 space-y-16">
              {latestPosts.map((post, i) => (
                <PostCard post={post} index={i + 1} />
              ))}
              {hasMore && (
                <a href={`${base}/blog?category=${encodeURIComponent(cat)}`}
                   class="inline-block font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500 hover:text-accent transition-colors">
                  查看全部 {catPosts.length} 篇 →
                </a>
              )}
            </div>
            <aside class="hidden lg:block col-span-4"></aside>
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
