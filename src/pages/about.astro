---
import BaseLayout from '../layouts/BaseLayout.astro';

const stack = [
  { label: 'Tools',    items: ['Unreal', 'Unity', 'Blender', 'Maya'] },
  { label: 'Code',     items: ['Python · PyTorch', 'C++ · C#', 'TypeScript'] },
  { label: 'Research', items: ['Transformer', 'Motion Matching', 'PFNN', 'Diffusion'] },
  { label: 'Writing',  items: ['Astro', 'Tailwind', 'Markdown', 'Obsidian'] },
];

const now = [
  { label: 'Learning',  value: 'Transformer / Attention 底层机制' },
  { label: 'Building',  value: '技术动画管线与 AI 生成 demo' },
  { label: 'Playing',   value: 'ARC Raiders · Elden Ring' },
  { label: 'Reading',   value: 'Character Animation With Direct3D' },
];
---

<BaseLayout title="About" wide={true}>
  <section class="pt-8 sm:pt-16 pb-24">
    <div class="flex items-center justify-between mb-10 font-mono text-[11px] uppercase tracking-widest text-ink-500">
      <span>§ Colophon</span>
      <span>About the author</span>
    </div>

    <h1 class="display text-display-xl">
      <span class="block">Hi, I'm</span>
      <span class="block display-italic text-accent">纸橙.</span>
    </h1>

    <div class="mt-16 grid grid-cols-12 gap-6 sm:gap-10">
      <div class="col-span-12 sm:col-span-7 sm:col-start-2">
        <p class="eyebrow mb-4">— The story</p>
        <div class="space-y-6 font-serif text-xl sm:text-[1.35rem] text-ink-700 leading-relaxed">
          <p>
            我是一名<span class="display-italic text-accent">技术动画</span>实习生，
            正在走向 Technical Animator 的方向。
          </p>
          <p>
            对我来说，动画不只是"让角色动起来"——
            每一帧里藏着物理、曲线、情绪、意图。
            我想去理解这些细节，再用<span class="display-italic">代码</span>把它们重新组织出来。
          </p>
          <p>
            最近被 AI 与动画的结合深深吸引，
            在学习 Transformer 和 Motion Matching 等技术的底层原理。
            这间小屋是我慢慢思考的地方。
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ======================== Now ======================== */}
  <section class="pb-24 reveal">
    <div class="hairline-t pt-8 mb-8">
      <div class="flex items-baseline justify-between">
        <p class="eyebrow">§ Now</p>
        <span class="font-mono text-[11px] tabular-nums text-ink-300">
          {new Date().toISOString().slice(0, 10)}
        </span>
      </div>
      <h2 class="display text-display-md mt-2">
        What I'm <span class="display-italic text-accent">up to</span>.
      </h2>
    </div>

    <dl class="grid grid-cols-12 gap-4 sm:gap-6">
      {now.map((item, i) => (
        <div class="col-span-12 sm:col-span-6 hairline-t pt-4 flex gap-4">
          <span class="index-num pt-1">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <dt class="eyebrow mb-1">{item.label}</dt>
            <dd class="font-serif text-xl text-ink-900">{item.value}</dd>
          </div>
        </div>
      ))}
    </dl>
  </section>

  {/* ======================== Stack ======================== */}
  <section class="pb-24 reveal">
    <div class="hairline-t pt-8 mb-8">
      <p class="eyebrow">§ Stack</p>
      <h2 class="display text-display-md mt-2">
        Things I <span class="display-italic text-accent">use</span>.
      </h2>
    </div>

    <div class="grid grid-cols-12 gap-4 sm:gap-6">
      {stack.map((group) => (
        <div class="col-span-12 sm:col-span-6 hairline-t pt-5">
          <p class="eyebrow mb-3">— {group.label}</p>
          <ul class="space-y-1 font-serif text-xl text-ink-900">
            {group.items.map((it) => (
              <li class="flex items-baseline gap-3">
                <span class="font-mono text-[11px] text-ink-300">+</span>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  {/* ======================== Contact ======================== */}
  <section class="pb-8 reveal">
    <div class="hairline-t pt-10">
      <p class="eyebrow mb-3">§ Say hi</p>
      <h2 class="display text-display-lg mb-8">
        Let's <span class="display-italic text-accent">talk</span>.
      </h2>

      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 sm:col-span-6">
          <p class="font-serif text-xl text-ink-700 leading-relaxed max-w-md">
            如果你也对动画、AI、或者只是想聊聊——
            随时找我，我会很高兴。
          </p>
        </div>
        <div class="col-span-12 sm:col-span-6 sm:col-start-8">
          <ul class="space-y-3">
            <li>
              <a href="https://github.com/zhichengZC" target="_blank" rel="noopener"
                 class="flex items-baseline justify-between py-3 hairline-b group">
                <span class="font-serif text-xl text-ink-900 group-hover:text-accent transition-colors">GitHub</span>
                <span class="font-mono text-xs text-ink-500 group-hover:text-accent transition-colors">@zhichengZC ↗</span>
              </a>
            </li>
            <li>
              <a href="/rss.xml"
                 class="flex items-baseline justify-between py-3 hairline-b group">
                <span class="font-serif text-xl text-ink-900 group-hover:text-accent transition-colors">RSS</span>
                <span class="font-mono text-xs text-ink-500 group-hover:text-accent transition-colors">/rss.xml ↗</span>
              </a>
            </li>
            <li>
              <a href="mailto:hello@example.com"
                 class="flex items-baseline justify-between py-3 hairline-b group">
                <span class="font-serif text-xl text-ink-900 group-hover:text-accent transition-colors">Email</span>
                <span class="font-mono text-xs text-ink-500 group-hover:text-accent transition-colors">hello@… ↗</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
