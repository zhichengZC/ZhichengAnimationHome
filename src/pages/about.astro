---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/site-config.json';

const stack = [
  { label: 'Tools',    items: ['Unreal', 'Unity', 'Blender', 'Maya'] },
  { label: 'Code',     items: ['Python · PyTorch', 'C++ · C#', 'TypeScript'] },
  { label: 'Research', items: ['Transformer', 'Motion Matching', 'PFNN', 'Diffusion'] },
  { label: 'Writing',  items: ['Astro', 'Tailwind', 'Markdown', 'Obsidian'] },
];

const now = [
  { label: 'Learning',  value: 'Transformer / Attention 底层机制' },
  { label: 'Building',  value: '技术动画管线与 AI 生成 demo' },
  { label: 'Playing',   value: 'ARC Raiders · Elden Ring' },
  { label: 'Reading',   value: 'Character Animation with Direct3D' },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cfg = siteConfig;
---

<BaseLayout title="About" wide={true}>

  <section class="pt-16 sm:pt-24 pb-16">
    <div class="grid grid-cols-12 gap-8 lg:gap-16 items-start">

      <div class="col-span-12 lg:col-span-8">
        <div class="flex items-center gap-3 mb-10">
          <span class="font-mono text-[10.5px] uppercase tracking-[0.24em] text-ink-500">— About</span>
          <span class="h-px flex-1 max-w-[60px] bg-ink-200"></span>
          <span class="font-mono text-[10.5px] uppercase tracking-[0.24em] text-ink-300">№ 03</span>
        </div>

        <h1 class="font-display leading-[1] text-[clamp(2.5rem,7vw,6rem)] tracking-[-0.035em] text-ink-900">
          Hi, I'm <span class="display-italic text-accent">纸橙</span>.
        </h1>

        <div class="mt-12 space-y-6 font-serif text-[17px] sm:text-lg text-ink-700 leading-[1.85] max-w-[54ch]">
          <p>
            一名技术动画实习生。对我来说，动画不只是让角色动起来——
            每一帧里藏着物理、曲线、情绪和意图。
          </p>
          <p>
            最近在学 Transformer 和 Motion Matching 的底层原理，
            也在看 AI 和动画怎么结合。
            <span class="text-ink-500">这里是我慢慢记下这些想法的地方。</span>
          </p>
        </div>
      </div>

      <aside class="col-span-12 lg:col-span-4 lg:pt-4 space-y-8">
        <div class="hairline-t pt-4">
          <dl class="space-y-5">
            <div class="flex items-baseline gap-5">
              <dt class="w-16 shrink-0 font-mono text-[10.5px] uppercase tracking-[0.22em] text-ink-300 pt-1">Role</dt>
              <dd class="flex-1 font-serif text-[15px] text-ink-900">{cfg.about.role}</dd>
            </div>
            <div class="flex items-baseline gap-5">
              <dt class="w-16 shrink-0 font-mono text-[10.5px] uppercase tracking-[0.22em] text-ink-300 pt-1">Based</dt>
              <dd class="flex-1 font-serif text-[15px] text-ink-900">{cfg.about.based}</dd>
            </div>
            <div class="flex items-baseline gap-5">
              <dt class="w-16 shrink-0 font-mono text-[10.5px] uppercase tracking-[0.22em] text-ink-300 pt-1">Writes</dt>
              <dd class="flex-1 font-serif text-[15px] text-ink-900">{cfg.about.writes}</dd>
            </div>
            <div class="flex items-baseline gap-5">
              <dt class="w-16 shrink-0 font-mono text-[10.5px] uppercase tracking-[0.22em] text-ink-300 pt-1">Drinks</dt>
              <dd class="flex-1 font-serif text-[15px] text-ink-900">{cfg.about.drinks}</dd>
            </div>
          </dl>
        </div>

        <div class="hairline-t pt-6">
          <svg viewBox="0 0 180 40" class="w-[140px] h-auto" aria-hidden="true">
            <path d="M4 28 Q18 8, 32 24 T62 22 Q72 10, 84 26 Q94 36, 108 20 T140 24 Q152 16, 168 22"
                  fill="none" stroke="rgb(var(--ink-500))" stroke-width="1.4" stroke-linecap="round"/>
            <circle cx="172" cy="24" r="1.6" fill="rgb(var(--accent))"/>
          </svg>
          <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.22em] text-ink-300">signed · 纸橙</p>
        </div>
      </aside>
    </div>
  </section>

  {/* ======= Now ======= */}
  <section class="pb-20 reveal">
    <div class="grid grid-cols-12 gap-8 lg:gap-16">
      <div class="col-span-12 lg:col-span-8">
        <div class="flex items-baseline justify-between mb-8 hairline-t pt-6">
          <p class="eyebrow">Now &nbsp;·&nbsp; 最近</p>
          <span class="font-mono text-[10.5px] tabular-nums text-ink-300">{new Date().toISOString().slice(0,10)}</span>
        </div>
        <dl class="grid grid-cols-12 gap-6">
          {now.map((item) => (
            <div class="col-span-12 sm:col-span-6 hairline-t pt-4">
              <dt class="eyebrow mb-1">{item.label}</dt>
              <dd class="font-serif text-[17px] text-ink-900">{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  {/* ======= Stack ======= */}
  <section class="pb-20 reveal">
    <div class="grid grid-cols-12 gap-8 lg:gap-16">
      <div class="col-span-12 lg:col-span-8">
        <p class="eyebrow hairline-t pt-6 mb-8">Stack &nbsp;·&nbsp; 工具</p>
        <div class="grid grid-cols-12 gap-6">
          {stack.map((group) => (
            <div class="col-span-12 sm:col-span-6 hairline-t pt-5">
              <p class="eyebrow mb-3">{group.label}</p>
              <ul class="space-y-1.5 font-serif text-[17px] text-ink-900">
                {group.items.map((it) => (
                  <li class="flex items-baseline gap-3">
                    <span class="font-mono text-[11px] text-ink-300">+</span>
                    <span>{it}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ======= Say hi ======= */}
  <section class="pb-12 reveal">
    <div class="grid grid-cols-12 gap-8 lg:gap-16">
      <div class="col-span-12 lg:col-span-8">
        <p class="eyebrow hairline-t pt-6 mb-6">Say hi</p>
        <ul class="space-y-0">
          {cfg.about.social.map((item) => (
          <li>
            <a href={item.href} target="_blank" rel="noopener"
               class="flex items-baseline justify-between py-4 hairline-b group">
              <span class="font-serif text-lg text-ink-900 group-hover:text-accent-deep transition-colors">{item.label}</span>
              <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500 group-hover:text-accent transition-all group-hover:translate-x-1">{item.handle} ↗</span>
            </a>
          </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
