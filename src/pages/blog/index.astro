---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const grouped = posts.reduce((acc, p) => {
  const y = p.data.pubDate.getFullYear();
  (acc[y] ||= []).push(p);
  return acc;
}, {} as Record<number, typeof posts>);
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);

const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags))).sort();
---

<BaseLayout title="Writing" wide={true}>
  <section class="pt-8 sm:pt-16 pb-20">
    {/* Masthead */}
    <div class="flex items-center justify-between mb-10 font-mono text-[11px] uppercase tracking-widest text-ink-500">
      <span>§ Archive</span>
      <span>{posts.length.toString().padStart(3, '0')} entries</span>
    </div>

    <h1 class="display text-display-xl">
      <span class="block">All the</span>
      <span class="block display-italic text-accent">writing.</span>
    </h1>

    <div class="mt-10 grid grid-cols-12 gap-6">
      <p class="col-span-12 sm:col-span-6 sm:col-start-2 font-serif text-xl text-ink-700 leading-relaxed">
        按时间倒序排列的所有文章。点击进入任意一篇，或在下方按标签索引。
      </p>
    </div>

    {/* Tag index */}
    {allTags.length > 0 && (
      <div class="mt-12 hairline-t pt-6">
        <p class="eyebrow mb-3">— Topics</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-[12px] uppercase tracking-widest">
          {allTags.map((t) => (
            <a href={`#tag-${t}`} class="text-ink-500 hover:text-accent transition-colors">
              {t}
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  {/* ============ Entries by year ============ */}
  {posts.length === 0 ? (
    <div class="py-24 text-center hairline-t">
      <p class="font-serif text-2xl text-ink-500">
        尚未开始 · <span class="display-italic">coming soon</span>
      </p>
    </div>
  ) : (
    <div class="space-y-20">
      {years.map((year) => (
        <section class="relative">
          <div class="flex items-end justify-between mb-2 reveal">
            <h2 class="display text-display-lg text-ink-900 leading-none">
              {year}
            </h2>
            <span class="font-mono text-[11px] uppercase tracking-widest text-ink-500 pb-2">
              {grouped[year].length} {grouped[year].length > 1 ? 'entries' : 'entry'}
            </span>
          </div>
          <div class="hairline-t">
            {grouped[year].map((post, i) => (
              <PostCard post={post} index={i + 1} />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</BaseLayout>
