---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by year
const grouped = posts.reduce((acc, p) => {
  const y = p.data.pubDate.getFullYear();
  (acc[y] ||= []).push(p);
  return acc;
}, {} as Record<number, typeof posts>);
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);

// All tags
const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags))).sort();
---

<BaseLayout title="文章">
  <section class="py-8">
    {/* ===== Header ===== */}
    <header class="mb-12 reveal relative">
      <div class="absolute -top-8 -left-4 text-paper-200 text-8xl font-serif opacity-50 pointer-events-none select-none">"</div>
      <p class="font-hand text-2xl text-paper-600 mb-2 relative">all posts</p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-ink-900 mb-4 relative flex items-center gap-3">
        <span class="section-title p-0 font-serif text-4xl sm:text-5xl font-bold">
          <span></span>
        </span>
        文章归档
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-ink-500 relative">
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-paper-500 animate-glow-pulse"></span>
          共 <span class="text-paper-600 font-semibold">{posts.length}</span> 篇
        </span>
        <span class="text-paper-300">·</span>
        <span>按时间倒序</span>
        <span class="text-paper-300">·</span>
        <span>{allTags.length} 个标签</span>
      </div>
    </header>

    {/* ===== Tag cloud ===== */}
    {allTags.length > 0 && (
      <div class="card p-5 mb-10 reveal">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs tracking-widest text-paper-600 font-semibold">TAGS</span>
          <div class="flex-1 h-px bg-gradient-to-r from-paper-200 to-transparent"></div>
        </div>
        <div class="flex flex-wrap gap-2">
          {allTags.map((t) => (
            <a href={`#${t}`} class="tag hover-wobble">#{t}</a>
          ))}
        </div>
      </div>
    )}

    {posts.length === 0 ? (
      <div class="card p-10 text-center reveal">
        <p class="text-5xl mb-3 inline-block animate-wave origin-bottom-right">�</p>
        <p class="text-ink-500">还没有文章，敬请期待～</p>
      </div>
    ) : (
      <div class="space-y-16">
        {years.map((year) => (
          <div class="relative">
            {/* Big year watermark */}
            <div class="absolute -top-6 right-0 font-serif text-8xl sm:text-9xl font-bold text-paper-200/40 select-none pointer-events-none -z-10">
              {year}
            </div>

            <div class="flex items-center gap-3 mb-6 reveal">
              <h2 class="font-serif text-3xl font-bold text-ink-900">{year}</h2>
              <span class="tag">{grouped[year].length} 篇</span>
              <div class="flex-1 h-px bg-gradient-to-r from-paper-300 to-transparent"></div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {grouped[year].map((post) => <PostCard post={post} />)}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
