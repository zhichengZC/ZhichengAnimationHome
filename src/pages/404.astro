---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" wide={true}>
  <section class="min-h-[70vh] flex flex-col justify-center py-20">
    <div class="flex items-center justify-between mb-12 font-mono text-[11px] uppercase tracking-widest text-ink-500">
      <span>§ Error</span>
      <span>Status 404</span>
    </div>

    <h1 class="display text-display-xl">
      <span class="block text-ink-200">404</span>
      <span class="block">Not <span class="display-italic text-accent">found</span>.</span>
    </h1>

    <p class="mt-12 font-serif text-xl sm:text-2xl text-ink-700 max-w-lg leading-relaxed">
      这一页被风吹走了，或者从未存在过。
      <br />
      但没关系，我们还有很多别的可以看。
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/" class="btn-primary">
        <span>返回首页</span><span aria-hidden>→</span>
      </a>
      <a href="/blog" class="btn-ghost">
        <span>去读文章</span><span aria-hidden>→</span>
      </a>
    </div>
  </section>
</BaseLayout>
