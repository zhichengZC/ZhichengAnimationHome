---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = allPosts.slice(0, 5);

const totalPosts = allPosts.length;
const totalTags = new Set(allPosts.flatMap((p) => p.data.tags)).size;
const firstDate = allPosts.length
  ? new Date(Math.min(...allPosts.map((p) => p.data.pubDate.valueOf())))
  : new Date();
const yearRange = `${firstDate.getFullYear()}—${new Date().getFullYear()}`;

const currentDate = new Date().toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: '2-digit',
});
---

<BaseLayout wide={true}>
  {/* ====================================================
   *  Section 01 — Hero
   * ==================================================== */}
  <section class="pt-8 sm:pt-16 pb-24 sm:pb-32">
    {/* Masthead meta row */}
    <div class="flex items-center justify-between mb-12 sm:mb-20 font-mono text-[11px] uppercase tracking-widest text-ink-500">
      <span>Issue № 001 · Vol. 1</span>
      <span class="hidden sm:inline">{currentDate}</span>
      <span class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        Now Writing
      </span>
    </div>

    {/* The big display title */}
    <h1 class="display text-display-xl animate-rise">
      <span class="block">纸上的</span>
      <span class="block">
        <span class="display-italic text-accent">animation</span>
        <span class="text-ink-300">,</span>
      </span>
      <span class="block">与思考。</span>
    </h1>

    {/* Description + CTA */}
    <div class="mt-12 sm:mt-16 grid grid-cols-12 gap-6 opacity-0 animate-rise" style="animation-delay: 0.2s;">
      <div class="col-span-12 sm:col-span-5 sm:col-start-2">
        <p class="eyebrow mb-3">— The premise</p>
        <p class="font-serif text-xl sm:text-2xl text-ink-700 leading-relaxed">
          一间安静的小屋，记录技术动画的学习、AI 与动画的边界，
          以及那些<span class="display-italic text-accent">值得</span>慢下来想一想的事。
        </p>
      </div>
      <div class="col-span-12 sm:col-span-5">
        <p class="eyebrow mb-3">— Contents</p>
        <ul class="space-y-2 text-[15px] text-ink-700">
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[11px] text-ink-300">01</span>
            <a href="/blog" class="link"><span>文章归档</span><span class="link-arrow">→</span></a>
          </li>
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[11px] text-ink-300">02</span>
            <a href="/about" class="link"><span>关于纸橙</span><span class="link-arrow">→</span></a>
          </li>
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[11px] text-ink-300">03</span>
            <a href="/rss.xml" class="link"><span>RSS 订阅</span><span class="link-arrow">↗</span></a>
          </li>
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[11px] text-ink-300">04</span>
            <a href="https://github.com/zhichengZC" target="_blank" rel="noopener" class="link">
              <span>GitHub</span><span class="link-arrow">↗</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* ====================================================
   *  Section 02 — Latest writing (editorial list)
   * ==================================================== */}
  <section class="pb-24 reveal">
    <div class="hairline-t pt-8 mb-6">
      <div class="flex items-baseline justify-between mb-2">
        <p class="eyebrow">§ 02 — Latest writing</p>
        <a href="/blog" class="link text-sm"><span>View all</span><span class="link-arrow">→</span></a>
      </div>
      <h2 class="display text-display-md">
        <span class="display-italic text-accent">Recent</span> dispatches.
      </h2>
    </div>

    {latest.length === 0 ? (
      <div class="py-24 text-center">
        <p class="font-serif text-2xl text-ink-500">
          还未发表 · <span class="display-italic">coming soon</span>
        </p>
      </div>
    ) : (
      <div class="mt-4 hairline-t">
        {latest.map((post, i) => (
          <PostCard post={post} index={i + 1} />
        ))}
      </div>
    )}
  </section>

  {/* ====================================================
   *  Section 03 — The author strip
   * ==================================================== */}
  <section class="pb-24 reveal">
    <div class="hairline-t pt-8 mb-10">
      <p class="eyebrow mb-2">§ 03 — Colophon</p>
      <h2 class="display text-display-md">
        By <span class="display-italic text-accent">纸橙</span>.
      </h2>
    </div>

    <div class="grid grid-cols-12 gap-6 sm:gap-10">
      <div class="col-span-12 sm:col-span-7">
        <p class="font-serif text-xl sm:text-2xl text-ink-700 leading-relaxed max-w-[52ch]">
          技术动画实习生。正在学习 Transformer 与动画系统，
          被 AI × 动画 的边界深深吸引。
          <span class="text-ink-500">
            相信把学到的东西写下来，思考才会真正留下痕迹。
          </span>
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/about" class="btn-primary">
            <span>关于纸橙</span>
            <span aria-hidden>→</span>
          </a>
          <a href="https://github.com/zhichengZC" target="_blank" rel="noopener" class="btn-ghost">
            <span>GitHub</span>
            <span aria-hidden>↗</span>
          </a>
        </div>
      </div>

      {/* Stats block */}
      <div class="col-span-12 sm:col-span-4 sm:col-start-9">
        <dl class="grid grid-cols-3 sm:grid-cols-1 gap-6">
          <div class="hairline-t pt-3">
            <dt class="eyebrow mb-1">Posts</dt>
            <dd class="font-display text-4xl sm:text-5xl text-ink-900 tabular-nums">{String(totalPosts).padStart(2, '0')}</dd>
          </div>
          <div class="hairline-t pt-3">
            <dt class="eyebrow mb-1">Topics</dt>
            <dd class="font-display text-4xl sm:text-5xl text-ink-900 tabular-nums">{String(totalTags).padStart(2, '0')}</dd>
          </div>
          <div class="hairline-t pt-3">
            <dt class="eyebrow mb-1">Since</dt>
            <dd class="font-display text-4xl sm:text-5xl text-ink-900 tabular-nums">{firstDate.getFullYear()}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  {/* ====================================================
   *  Tagline ticker
   * ==================================================== */}
  <section class="hairline-t hairline-b py-6 overflow-hidden">
    <div class="ticker-track font-display text-5xl sm:text-7xl text-ink-900 gap-8">
      {Array(2).fill(0).map(() => (
        <span class="flex items-center gap-8 px-4">
          <span>Record slowly.</span>
          <span class="accent-dot"></span>
          <span class="display-italic text-accent">Think deeply.</span>
          <span class="accent-dot"></span>
          <span>Write honestly.</span>
          <span class="accent-dot"></span>
          <span class="display-italic">Stay curious.</span>
          <span class="accent-dot"></span>
        </span>
      ))}
    </div>
  </section>
</BaseLayout>
