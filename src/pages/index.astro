---
import BaseLayout from '../layouts/BaseLayout.astro';
import Typewriter from '../components/Typewriter.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = allPosts.slice(0, 4);
---

<BaseLayout>
  {/* ========== Hero ========== */}
  <section class="relative py-16 sm:py-24 text-center overflow-hidden">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-10 left-1/4 text-6xl opacity-20 animate-float">🍊</div>
      <div class="absolute top-32 right-1/4 text-5xl opacity-20 animate-float" style="animation-delay: -2s">✨</div>
      <div class="absolute bottom-10 left-1/3 text-4xl opacity-20 animate-float" style="animation-delay: -4s">🌱</div>
    </div>

    <p class="text-paper-600 mb-4 tracking-widest text-sm animate-fade-in">· 欢迎来到 ·</p>

    <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl font-bold mb-6 animate-fade-in-up">
      <span class="gradient-text">纸橙的动画小屋</span>
    </h1>

    <div class="opacity-0 animate-fade-in-up" style="animation-delay: 0.3s; animation-fill-mode: forwards;">
      <Typewriter phrases={[
        '记录动画的温度 🎬',
        '沉淀技术的思考 💡',
        '分享生活的碎片 🌿',
        '一杯橙茶，慢慢聊。',
      ]} />
    </div>

    <div class="mt-10 flex flex-wrap gap-3 justify-center opacity-0 animate-fade-in-up" style="animation-delay: 0.6s; animation-fill-mode: forwards;">
      <a href="/blog" class="btn-primary">
        <span>开始阅读</span>
        <span>→</span>
      </a>
      <a href="/about" class="btn-ghost">
        <span>关于纸橙</span>
      </a>
    </div>
  </section>

  {/* ========== Latest ========== */}
  <section class="mt-12">
    <div class="flex items-end justify-between mb-8 reveal">
      <h2 class="font-serif text-2xl sm:text-3xl font-semibold text-ink-900">
        <span class="text-paper-500">◆</span>
        最新文章
      </h2>
      <a href="/blog" class="text-sm text-paper-600 hover:text-paper-700 transition-colors">
        查看全部 →
      </a>
    </div>

    {latest.length === 0 ? (
      <div class="card p-10 text-center reveal">
        <p class="text-4xl mb-3">📝</p>
        <p class="text-ink-500">小屋刚刚开张，第一篇文章即将到来～</p>
      </div>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2">
        {latest.map((post) => <PostCard post={post} />)}
      </div>
    )}
  </section>

  {/* ========== About strip ========== */}
  <section class="mt-24 reveal">
    <div class="card p-8 sm:p-10 text-center">
      <p class="text-5xl mb-4 inline-block animate-float">🍊</p>
      <h3 class="font-serif text-2xl font-semibold text-ink-900 mb-3">你好，我是纸橙</h3>
      <p class="text-ink-500 max-w-xl mx-auto leading-relaxed">
        技术动画实习生，正在学习 Transformer 与动画系统，热爱 AI 动画、游戏动态，
        也喜欢把思考慢慢写下来。这里是我的小小角落，欢迎常来坐坐 ☕
      </p>
      <a href="/about" class="btn-ghost mt-6">
        <span>更多关于我</span>
        <span>→</span>
      </a>
    </div>
  </section>
</BaseLayout>
