---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  index?: number;
}
const { post, index } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const rawBody = post.body || '';
const readMin = Math.max(1, Math.round(rawBody.length / 400));

const y = pubDate.getFullYear();
const m = String(pubDate.getMonth() + 1).padStart(2, '0');
const d = String(pubDate.getDate()).padStart(2, '0');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a
  href={`${base}/blog/${post.slug}/`}
  class="row-link group block py-8 hairline-b reveal post-card"
>
  <div class="grid grid-cols-12 gap-4 sm:gap-6 items-baseline relative">

    {/* Index + date — left column */}
    <div class="col-span-12 sm:col-span-3 flex sm:flex-col gap-3 sm:gap-1 items-baseline">
      {typeof index === 'number' && (
        <span class="index-num transition-colors duration-300 group-hover:text-accent">
          № {String(index).padStart(2, '0')}
        </span>
      )}
      <time datetime={pubDate.toISOString()} class="font-mono text-xs text-ink-500 tabular-nums">
        {y}.{m}.{d}
      </time>
      <span class="font-mono text-[11px] text-ink-300 tabular-nums sm:block hidden">
        {readMin} min read
      </span>
    </div>

    {/* Title + desc — main column */}
    <div class="col-span-12 sm:col-span-7">
      <h3 class="post-title font-display text-2xl sm:text-[2rem] leading-[1.15] text-ink-900 tracking-tight transition-colors duration-300 group-hover:text-accent-deep">
        {title}
      </h3>
      {description && (
        <p class="mt-3 text-ink-500 text-[15px] leading-relaxed clamp-2">
          {description}
        </p>
      )}
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.slice(0, 4).map((t) => (
            <span class="chip-tag">— {t}</span>
          ))}
        </div>
      )}
    </div>

    {/* Arrow — right column */}
    <div class="col-span-12 sm:col-span-2 flex sm:justify-end items-center">
      <span class="row-arrow font-display text-3xl text-ink-900 transition-all duration-500">→</span>
    </div>
  </div>
</a>

<style>
  .post-card { position: relative; }
  .post-title {
    background-image: linear-gradient(rgb(var(--accent)), rgb(var(--accent)));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 2px;
    transition: background-size 0.6s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s;
    padding-bottom: 2px;
  }
  .post-card:hover .post-title { background-size: 100% 2px; }

  .chip-tag {
    font-family: theme('fontFamily.mono');
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--ink-500));
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    transition: color 0.25s, background-color 0.25s;
  }
  .post-card:hover .chip-tag {
    color: rgb(var(--accent-deep));
  }
</style>
