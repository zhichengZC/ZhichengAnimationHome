---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  index?: number;
}
const { post, index } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const rawBody = post.body || '';
const readMin = Math.max(1, Math.round(rawBody.length / 400));

const y = pubDate.getFullYear();
const m = String(pubDate.getMonth() + 1).padStart(2, '0');
const d = String(pubDate.getDate()).padStart(2, '0');
---

<a href={`/blog/${post.slug}/`} class="row-link group block py-8 hairline-b reveal">
  <div class="grid grid-cols-12 gap-4 sm:gap-6 items-baseline">
    {/* Index + date — left column */}
    <div class="col-span-12 sm:col-span-3 flex sm:flex-col gap-3 sm:gap-1 items-baseline">
      {typeof index === 'number' && (
        <span class="index-num">{String(index).padStart(2, '0')}</span>
      )}
      <time datetime={pubDate.toISOString()} class="font-mono text-xs text-ink-500 tabular-nums">
        {y}.{m}.{d}
      </time>
      <span class="font-mono text-[11px] text-ink-300 tabular-nums sm:block hidden">
        {readMin} min read
      </span>
    </div>

    {/* Title + desc — main column */}
    <div class="col-span-12 sm:col-span-7">
      <h3 class="font-display text-2xl sm:text-[2rem] leading-[1.15] text-ink-900 tracking-tight transition-colors duration-300 group-hover:text-accent-deep">
        {title}
      </h3>
      {description && (
        <p class="mt-3 text-ink-500 text-[15px] leading-relaxed clamp-2">
          {description}
        </p>
      )}
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-x-3 gap-y-1 font-mono text-[11px] uppercase tracking-widest text-ink-500">
          {tags.slice(0, 4).map((t) => <span>— {t}</span>)}
        </div>
      )}
    </div>

    {/* Arrow — right column */}
    <div class="col-span-12 sm:col-span-2 flex sm:justify-end items-center">
      <span class="row-arrow font-display text-3xl text-ink-900">→</span>
    </div>
  </div>
</a>
