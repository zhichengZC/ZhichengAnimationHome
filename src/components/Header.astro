---
import { NAV_LINKS, SITE_TITLE } from '../consts';

const { pathname } = Astro.url;
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-paper-50/75 border-b border-paper-100">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-2.5">
      <span class="text-2xl transition-transform group-hover:rotate-12 group-hover:scale-110 duration-500">🍊</span>
      <span class="font-serif text-lg font-semibold text-ink-900 tracking-wide">{SITE_TITLE}</span>
    </a>

    <ul class="flex items-center gap-1 sm:gap-2">
      {NAV_LINKS.map((link) => {
        const isActive = link.href === '/'
          ? pathname === '/'
          : pathname.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-300',
                isActive
                  ? 'bg-paper-200 text-ink-900'
                  : 'text-ink-500 hover:bg-paper-100 hover:text-ink-900',
              ]}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
