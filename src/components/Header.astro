---
import { NAV_LINKS, SITE_TITLE } from '../consts';
const { pathname } = Astro.url;
---

<header class="sticky top-0 z-40 bg-bg/80 backdrop-blur-md hairline-b">
  <nav class="max-w-page mx-auto px-6 sm:px-10 h-16 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-2.5 select-none">
      <span class="accent-dot"></span>
      <span class="font-display text-[1.35rem] text-ink-900 tracking-tight leading-none">
        {SITE_TITLE}
      </span>
    </a>

    <ul class="flex items-center gap-1 text-sm">
      {NAV_LINKS.map((link) => {
        const isActive = link.href === '/'
          ? pathname === '/'
          : pathname.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                'relative inline-flex items-center px-3 py-2 transition-colors duration-300',
                isActive ? 'text-ink-900' : 'text-ink-500 hover:text-ink-900',
              ]}
            >
              {isActive && <span class="accent-dot mr-2 !w-1.5 !h-1.5 !shadow-none"></span>}
              <span>{link.label}</span>
            </a>
          </li>
        );
      })}
      <li class="ml-2 pl-3 border-l border-ink-200">
        <a href="/rss.xml" class="text-ink-500 hover:text-accent transition-colors" aria-label="RSS">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1"/>
          </svg>
        </a>
      </li>
    </ul>
  </nav>
</header>
